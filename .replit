run = "bash .replit-start.sh"
modules = ["nodejs-22", "postgresql-16", "python-3.11"]

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3001

[[ports]]
localPort = 5175
externalPort = 3003

[[ports]]
localPort = 5176
externalPort = 3002

[[ports]]
localPort = 5177
externalPort = 4200

[[ports]]
localPort = 5178
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 23566
externalPort = 3000

[userenv]

[userenv.shared]
DATABASE_PROVIDER = "postgresql"

[deployment]
deploymentTarget = "cloudrun"

[nix]
packages = ["zip"]
channel = "stable-25_05"
